---
permalink: /SearchData.json
---
{
  {%- assign search_items = site.notes | concat: site.posts | concat: site.pages -%}
  {%- assign i = 0 -%}
  {%- for item in search_items -%}
    {%- unless item.url contains 'SearchData' or item.url contains '404' or item.feed == 'hide' -%}
      {%- if i > 0 -%},{%- endif -%}
      "{{ i }}": {
        "doc": {{ item.title | default: item.name | strip_html | escape | jsonify }},
        "title": {{ item.title | default: item.name | strip_html | escape | jsonify }},
        "content": {{ item.content | replace: '</h', ' . </h' | replace: '<hr', ' . <hr' | replace: '</p', ' . </p' | replace: '<ul', ' . <ul' | replace: '</ul', ' . </ul' | replace: '<ol', ' . <ol' | replace: '</ol', ' . </ol' | replace: '</tr', ' . </tr' | replace: '<li', ' | <li' | replace: '</li', ' | </li' | replace: '</td', ' | </td' | replace: '<td', ' | <td' | replace: '</th', ' | </th' | replace: '<th', ' | <th' | strip_html | remove: 'Table of contents' | normalize_whitespace | replace: '. . .', '.' | replace: '. .', '.' | replace: '| |', '|' | append: ' ' | strip_newline | strip | escape | jsonify }},
        "url": "{{ item.url | relative_url }}",
        "type": "{%- if item.collection == 'posts' -%}post{%- elsif item.collection == 'notes' -%}note{%- else -%}page{%- endif -%}"
      }
      {%- assign i = i | plus: 1 -%}
    {%- endunless -%}
  {%- endfor -%}
}
